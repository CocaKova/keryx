<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Save-to-device on pre-Q only; Android 10+ writes via MediaStore with no permission. -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <!-- Post message notifications (runtime-requested on Android 13+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Lets Keryx ask to be exempt from battery optimization so the OS (esp. Samsung's
         aggressive "deep sleep" freezing) doesn't suspend the Matrix sync while backgrounded —
         this is what keeps messages arriving without a persistent foreground-service notification. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Built-in push (no distributor app): a foreground service holds Keryx's own WebSocket to
         the user's ntfy server. specialUse because none of the enumerated types fit "self-hosted
         push transport" — and unlike dataSync it may restart straight from BOOT_COMPLETED. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Voice replies: package-visibility rule so the built-in TextToSpeech engine is bindable
         under targetSdk 30+ filtering. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE" />
        </intent>
    </queries>

    <application
        android:name=".KeryxApp"
        android:usesCleartextTraffic="true"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HermesChat">
        <activity
            android:name=".MainActivity"
            android:windowSoftInputMode="adjustResize"
            android:launchMode="singleTop"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- System share-sheet target: text/links and any file type Matrix can carry. Its own
             activity (not MainActivity) so a share never disturbs the main task stack. -->
        <activity
            android:name=".share.ShareActivity"
            android:windowSoftInputMode="adjustResize"
            android:excludeFromRecents="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
                <data android:mimeType="video/*" />
                <data android:mimeType="audio/*" />
                <data android:mimeType="application/*" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- UnifiedPush: the distributor wakes this service with pushed Matrix event ids. -->
        <service
            android:name=".notify.KeryxPushService"
            android:exported="false">
            <intent-filter>
                <action android:name="org.unifiedpush.android.connector.PUSH_EVENT" />
            </intent-filter>
        </service>

        <!-- Built-in push: Keryx's own subscription to the user's ntfy server when no
             UnifiedPush distributor app is installed. -->
        <service
            android:name=".notify.BuiltinPushService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Maintains the WebSocket that delivers self-hosted push notifications when no UnifiedPush distributor app is installed" />
        </service>

        <!-- Restarts built-in push after reboot / app update (a distributor app would have
             survived those on its own; without one that job is ours). -->
        <receiver
            android:name=".notify.BuiltinPushBootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Notification action buttons (inline reply + ⟦keryx:ask⟧ options) land here. -->
        <receiver
            android:name=".notify.NotificationActionReceiver"
            android:exported="false" />
    </application>

</manifest>
